<launch>
    <include file="$(find imu_bno055)/launch/imu.launch" />
    <include file="$(find rplidar_ros)/launch/rplidar.launch" />

    <node pkg="laser_filters" type="scan_to_cloud_filter_chain"
        name="tilt_shadow_filter">
        <rosparam command="load" file="$(find my_robot_bringup)/config/lidar_config.yaml" />
        <rosparam command="load" file="$(find my_robot_bringup)/config/pointcloud_config.yaml" />
        <param name="high_fidelity" value="true" />
        <param name="target_frame" type="string" value="baselink" />
        <param name="notifier_tolerance" type="double" value="10" />
        <remap from="scan" to="tilt_scan" />-->
    </node>

    <node name="kalman_filter" pkg="my_robot_control" type="kalman_filter" output="screen"/>
</launch>